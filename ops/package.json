{
  "name": "@remote-codex/ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "remote-codex-ops": "./dist/cli-main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@remote-codex/server": "workspace:*",
    "@remote-codex/shared": "workspace:*"
  },
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "pretest": "corepack pnpm --filter @remote-codex/shared build && corepack pnpm --filter @remote-codex/server build",
    "test": "vitest run --coverage",
    "test:without-e2e": "vitest run --coverage",
    "build": "tsc --project tsconfig.json"
  }
}
